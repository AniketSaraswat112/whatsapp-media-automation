# n8n configuration
# See: https://docs.n8n.io/hosting/configuration/environment-variables/

# Port n8n listens on (default: 5678)
N8N_PORT=5678

# Host n8n binds to
N8N_HOST=localhost

# Set to "production" for live use, "development" for local dev
NODE_ENV=development

# Base URL for webhook callbacks (update if exposing publicly)
# WEBHOOK_URL=https://your-domain.com/

# Timezone for cron/schedule triggers
GENERIC_TIMEZONE=UTC

# Data persistence directory (defaults to ~/.n8n)
# N8N_USER_FOLDER=/path/to/your/.n8n

# Optional: basic auth to protect the UI
# N8N_BASIC_AUTH_ACTIVE=true
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=changeme

# Optional: disable telemetry
# N8N_DIAGNOSTICS_ENABLED=false
